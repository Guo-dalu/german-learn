  "dialogues": [
    {
      "id": "supermarket",
      "scene": { "en": "Anna and Thomas run into each other at the supermarket.", "zh": "Anna 和 Thomas 在超市相遇。" },
      "audio": "food-dialogue-1.mp3",
      "highlighted_words": ["Brot", "Milch", "Eier", "Käse", "Fleisch", "Suppe", "Zwiebel", "Kartoffeln", "Apfel"],
      "lines": [
        { "speaker": "Thomas", "text": "Hallo Anna! Was kaufst du heute?" },
        { "speaker": "Anna",   "text": "Ich kaufe Brot, Milch und Eier. Und du?" },
        { "speaker": "Thomas", "text": "Ich brauche Käse und Fleisch. Ich koche heute Abend." },
        { "speaker": "Anna",   "text": "Oh, ich esse auch gern Käse! Hast du eine Suppe geplant?" },
        { "speaker": "Thomas", "text": "Nein, aber die Idee ist gut. Vielleicht kaufe ich noch eine Zwiebel und Kartoffeln." },
        { "speaker": "Anna",   "text": "Der Apfel hier sieht lecker aus!" },
        { "speaker": "Thomas", "text": "Ja! Das Obst ist heute frisch. Guten Einkauf!" },
        { "speaker": "Anna",   "text": "Danke, dir auch!" }
      ]
    },
    {
      "id": "cafe",
      "scene": { "en": "Lisa orders breakfast at a café.", "zh": "Lisa 在咖啡馆点早餐。" },
      "audio": "food-dialogue-2.mp3",
      "highlighted_words": ["Kaffee", "Milch", "Saft", "Ei", "Butter", "Brot", "Banane", "Orange"],
      "lines": [
        { "speaker": "Kellner", "text": "Guten Morgen! Was möchten Sie?" },
        { "speaker": "Lisa",    "text": "Guten Morgen! Ich hätte gern einen Kaffee und ein Croissant." },
        { "speaker": "Kellner", "text": "Mit Milch oder schwarz?" },
        { "speaker": "Lisa",    "text": "Mit Milch, bitte. Und haben Sie frischen Orangensaft?" },
        { "speaker": "Kellner", "text": "Ja, natürlich. Möchten Sie auch etwas essen?" },
        { "speaker": "Lisa",    "text": "Ja, ein Ei mit Butter und Brot, bitte." },
        { "speaker": "Kellner", "text": "Sehr gern. Und zum Nachtisch? Wir haben frische Bananen und Orangen." },
        { "speaker": "Lisa",    "text": "Eine Banane, danke. Das reicht." }
      ]
    }
