        { "speaker": "Felix", "text": "Guten Morgen, Nina! Wie war dein Wochenende?" },
        { "speaker": "Nina",  "text": "Leider nicht so gut. Ich habe am Samstag Überstunden gemacht." },
        { "speaker": "Felix", "text": "Wirklich? Wegen der Deadline am Montag?" },
        { "speaker": "Nina",  "text": "Genau. Aber der Bericht ist jetzt fertig. Und du?" },
        { "speaker": "Felix", "text": "Ich war im Homeoffice — sehr produktiv! Wann ist die Besprechung heute?" },
        { "speaker": "Nina",  "text": "Um elf. Danach machen wir Mittagspause?" },
        { "speaker": "Felix", "text": "Ja, gerne! Ich habe noch so viele Aufgaben heute." }
      ]
    },
