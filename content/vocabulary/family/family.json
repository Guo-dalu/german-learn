  "dialogues": [
    {
      "id": "talking-about-family",
      "scene": { "en": "Emma and Noah talk about their families at a language course.", "zh": "Emma 和 Noah 在语言课上聊家人。" },
      "audio": "family-dialogue-1.mp3",
      "highlighted_words": ["Familie", "Geschwister", "Bruder", "Schwester", "Eltern", "Kind", "Großeltern"],
      "lines": [
        { "speaker": "Noah",  "text": "Hast du Geschwister?" },
        { "speaker": "Emma",  "text": "Ja, einen Bruder und eine Schwester. Und du?" },
        { "speaker": "Noah",  "text": "Ich bin Einzelkind. Aber ich habe viele Cousins." },
        { "speaker": "Emma",  "text": "Sind deine Eltern noch zusammen?" },
        { "speaker": "Noah",  "text": "Ja, seit dreißig Jahren verheiratet! Und deine Familie?" },
        { "speaker": "Emma",  "text": "Meine Eltern auch. Und meine Großeltern leben noch — sie sind über achtzig." },
        { "speaker": "Noah",  "text": "Das ist wunderbar. Hast du selbst Kinder?" },
        { "speaker": "Emma",  "text": "Nein, noch nicht. Ich bin erst sechsundzwanzig." }
      ]
    },
    {
      "id": "showing-photos",
      "scene": { "en": "Luca shows his phone photos to a colleague.", "zh": "Luca 把手机里的照片给同事看。" },
      "audio": "family-dialogue-2.mp3",
      "highlighted_words": ["Frau", "Sohn", "Tochter", "Baby", "Vater", "Mutter", "Hochzeit"],
      "lines": [
        { "speaker": "Luca",   "text": "Schau mal — das ist meine Frau und unsere Kinder." },
        { "speaker": "Kollegin", "text": "Oh, wie süß! Wie alt ist der Sohn?" },
        { "speaker": "Luca",   "text": "Der Sohn ist vier, die Tochter ist zwei. Und das hier ist unser neues Baby." },
        { "speaker": "Kollegin", "text": "Drei Kinder! Und das hier — eine Hochzeit?" },
        { "speaker": "Luca",   "text": "Ja, das sind meine Eltern — mein Vater und meine Mutter. Ihr fünfundzwanzigster Hochzeitstag." },
        { "speaker": "Kollegin", "text": "Fünfundzwanzig Jahre — das ist toll!" },
        { "speaker": "Luca",   "text": "Ja, sie sind noch sehr verliebt." }
      ]
    }
  ],
