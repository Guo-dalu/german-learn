  "dialogues": [
    {
      "id": "apartment-viewing",
      "scene": { "en": "Sarah views an apartment with the landlord.", "zh": "Sarah 和房东一起看公寓。" },
      "audio": "apartment-dialogue-1.mp3",
      "highlighted_words": ["Wohnung", "Zimmer", "Küche", "Badezimmer", "Wohnzimmer", "Schlafzimmer", "Balkon", "Miete"],
      "lines": [
        { "speaker": "Vermieter", "text": "Willkommen! Das ist die Wohnung. Sie hat drei Zimmer." },
        { "speaker": "Sarah",     "text": "Sehr schön! Wo ist die Küche?" },
        { "speaker": "Vermieter", "text": "Die Küche ist hier links, und das Badezimmer ist gegenüber." },
        { "speaker": "Sarah",     "text": "Das Wohnzimmer ist groß! Und das Schlafzimmer?" },
        { "speaker": "Vermieter", "text": "Das Schlafzimmer ist am Ende des Flurs. Es hat auch einen Balkon." },
        { "speaker": "Sarah",     "text": "Wunderbar. Wie hoch ist die Miete?" },
        { "speaker": "Vermieter", "text": "Achthundert Euro pro Monat, warm." },
        { "speaker": "Sarah",     "text": "Das ist fair. Ich melde mich morgen!" }
      ]
    },
    {
      "id": "new-neighbor",
      "scene": { "en": "Kai meets his new neighbor in the hallway.", "zh": "Kai 在走廊遇到新邻居。" },
      "audio": "apartment-dialogue-2.mp3",
      "highlighted_words": ["Flur", "Stockwerk", "Aufzug", "Treppe", "Schlüssel", "Tür"],
      "lines": [
        { "speaker": "Kai",      "text": "Hallo! Bist du neu hier im Haus?" },
        { "speaker": "Mia",      "text": "Ja, ich bin eingezogen! Ich bin Mia. Ich wohne im zweiten Stockwerk." },
        { "speaker": "Kai",      "text": "Ich auch! Ich bin Kai. Nimmst du den Aufzug oder die Treppe?" },
        { "speaker": "Mia",      "text": "Meistens die Treppe. Der Aufzug ist so langsam." },
        { "speaker": "Kai",      "text": "Stimmt! Oh, deine Tür steht offen." },
        { "speaker": "Mia",      "text": "Ach so! Ich habe meinen Schlüssel dringelassen. Danke!" },
        { "speaker": "Kai",      "text": "Kein Problem. Schöne neue Nachbarschaft!" }
      ]
    },
    {
      "id": "broken-shower",
      "scene": { "en": "Tom calls his landlord to report a broken shower.", "zh": "Tom 打电话给房东报告淋浴坏了。" },
      "audio": "apartment-dialogue-3.mp3",
      "highlighted_words": ["Dusche", "Badewanne", "Heizung", "Stockwerk", "Vermieter"],
      "lines": [
        { "speaker": "Tom",       "text": "Guten Tag, Herr Bauer. Hier ist Tom aus dem zweiten Stockwerk." },
        { "speaker": "Vermieter", "text": "Hallo, Tom! Was kann ich für Sie tun?" },
        { "speaker": "Tom",       "text": "Ich habe ein Problem mit der Dusche. Das Wasser wird nicht warm." },
        { "speaker": "Vermieter", "text": "Oh, das tut mir leid. Ist es nur die Dusche, oder auch die Badewanne?" },
        { "speaker": "Tom",       "text": "Nur die Dusche. Die Heizung funktioniert normal." },
        { "speaker": "Vermieter", "text": "Ich schicke morgen früh einen Klempner. Sind Sie bis zehn Uhr zu Hause?" },
        { "speaker": "Tom",       "text": "Ja, kein Problem. Ich warte auf ihn." },
        { "speaker": "Vermieter", "text": "Gut. Danke für die Info, und Entschuldigung für die Unannehmlichkeiten!" }
      ]
    }
  ],
