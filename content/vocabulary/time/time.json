      "highlighted_words": ["Datum", "Frühling", "Sommer", "Herbst", "Winter", "März"],
      "lines": [
        { "speaker": "Clara", "text": "Wann hast du Geburtstag?" },
        { "speaker": "Leo",   "text": "Am fünfzehnten März. Und du?" },
        { "speaker": "Clara", "text": "Ich bin im August geboren, mitten im Sommer!" },
        { "speaker": "Leo",   "text": "Oh schön! Mein Geburtstag ist im Frühling — manchmal ist es noch kalt." },
        { "speaker": "Clara", "text": "Welches Datum ist heute eigentlich?" },
        { "speaker": "Leo",   "text": "Der zweite November. Schon Herbst." },
        { "speaker": "Clara", "text": "Der Winter kommt bald. Ich mag den Winter nicht." },
        { "speaker": "Leo",   "text": "Ich schon — ich liebe Schnee!" }
      ]
    }
