      "highlighted_words": ["Wochenende", "Samstag", "Sonntag", "Uhr", "Abend", "Termin"],
      "lines": [
        { "speaker": "Anna", "text": "Was machst du am Wochenende?" },
        { "speaker": "Ben",  "text": "Am Samstag habe ich einen Termin um elf Uhr. Am Nachmittag bin ich frei." },
        { "speaker": "Anna", "text": "Wollen wir uns am Samstag um drei Uhr treffen?" },
        { "speaker": "Ben",  "text": "Ja, gerne! Und am Sonntag?" },
        { "speaker": "Anna", "text": "Sonntag schlafe ich lange. Erst am Abend bin ich wach." },
        { "speaker": "Ben",  "text": "Ich auch! Sonntag Abend kochen wir zusammen?" },
        { "speaker": "Anna", "text": "Super Idee. So gegen sieben Uhr?" },
        { "speaker": "Ben",  "text": "Perfekt. Dann bis Samstag!" }
      ]
    },
